---
import Layout from '@/layouts/Layout.astro'
import { withBase } from '@/lib/with-base'
---

<Layout title="Page Not Found | Rifki" description="The page you are looking for does not exist." noindex>
  <div class="font-base">
    <h1 class="text-2xl font-heading sm:text-4xl">404</h1>
    <p class="mt-4 text-base sm:text-lg">Page not found.</p>
    <a
      class="border-border dark:border-darkBorder shadow-light dark:shadow-dark mt-8 inline-block rounded-base border-2 bg-main px-4 py-2 text-sm font-base transition-all hover:translate-x-boxShadowX hover:translate-y-boxShadowY hover:shadow-none sm:text-base dark:hover:shadow-none"
      href={withBase()}
    >
      Back to home
    </a>
  </div>
</Layout>
